    {
      "name": "e0ae995d",
      "displayName": "Ventas_anuales",
      "queryLines": [
        "SELECT \r\n",
        "    year(order_date) AS year,\r\n",
        "    SUM(gross_amount) AS total_sales,\r\n",
        "    SUM(net_amount) AS net_sales,\r\n",
        "    COUNT(DISTINCT order_id) AS total_orders\r\n",
        "FROM catalog_finalproject.golden.fact_sales\r\n",
        "GROUP BY year\r\n",
        "ORDER BY year;"
      ]
    },
    {
      "name": "363a9dd1",
      "displayName": "Tendencia_mensual",
      "queryLines": [
        "SELECT \r\n",
        "    date_format(order_date, 'yyyy-MM') AS year_month,\r\n",
        "    SUM(gross_amount) AS total_sales\r\n",
        "FROM catalog_finalproject.golden.fact_sales\r\n",
        "GROUP BY year_month\r\n",
        "ORDER BY year_month;"
      ]
    },
    {
      "name": "ce3e865a",
      "displayName": "Productos_estrella",
      "queryLines": [
        "SELECT \r\n",
        "    p.product_name,\r\n",
        "    SUM(f.quantity) AS total_units,\r\n",
        "    SUM(f.gross_amount) AS revenue\r\n",
        "FROM catalog_finalproject.golden.fact_sales f\r\n",
        "JOIN catalog_finalproject.golden.dim_product p\r\n",
        "    ON f.product_id = p.product_id\r\n",
        "GROUP BY p.product_name\r\n",
        "ORDER BY revenue DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "a3d2bd25",
      "displayName": "Top Customers Ranked by Total Spending Amount",
      "queryLines": [
        "SELECT \r\n",
        "    c.customer_id,\r\n",
        "    c.name,\r\n",
        "    SUM(f.gross_amount) AS total_spent\r\n",
        "FROM catalog_finalproject.golden.fact_sales f\r\n",
        "JOIN catalog_finalproject.golden.dim_customer c\r\n",
        "    ON f.customer_id = c.customer_id\r\n",
        "GROUP BY c.customer_id, c.name\r\n",
        "ORDER BY total_spent DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "cba183b7",
      "displayName": "Ventas_por_sucursal",
      "queryLines": [
        "SELECT \r\n",
        "    branch_name,\r\n",
        "    state,\r\n",
        "    SUM(gross_amount) AS total_sales\r\n",
        "FROM catalog_finalproject.golden.fact_sales\r\n",
        "GROUP BY branch_name, state\r\n",
        "ORDER BY total_sales DESC;"
      ]
    }
  ],
